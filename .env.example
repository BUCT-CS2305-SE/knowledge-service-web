# ===========================================
# 海外文物知识服务系统 - 环境变量配置
# ===========================================

# ---- API 配置 ----
# 后端 API 基础地址（后期对接真实后端时修改）
VITE_API_BASE_URL=http://localhost:8080/api

# 是否使用 Mock 数据（开发阶段设为 true）
VITE_USE_MOCK=true

# ---- 开发服务器配置 ----
# 开发服务器端口（默认 5173）
VITE_DEV_PORT=5173

# 是否自动打开浏览器
VITE_DEV_OPEN=true

# ---- 构建配置 ----
# 生产环境基础路径（部署到子目录时需要设置）
# VITE_BASE_URL=/

# ---- 功能开关 ----
# 是否启用性能监控
VITE_ENABLE_PERF_MONITOR=false

# 是否启用错误上报
VITE_ENABLE_ERROR_REPORT=false

# ===========================================
# 使用说明：
#
# 1. 复制此文件为 .env.local：cp .env.example .env.local
# 2. 根据实际情况修改上述配置
# 3. .env.local 已加入 .gitignore，不会提交到仓库
#
# 注意：
# - 所有 VITE_ 开头的变量会在构建时注入到客户端代码
# - 不要在 VITE_ 变量中存储敏感信息（如密码、密钥）
# - 敏感信息应通过后端 API 获取
# ===========================================
